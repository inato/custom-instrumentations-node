{
  "name": "@inato/custom-instrumentations-node",
  "version": "0.5.0",
  "description": "Inato custom OpenTelementry instrumentation for NodeJS",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/inato/custom-instrumentations-node"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": "./build/index.js",
    "./register": "./build/register.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p .",
    "changeset-version": "changeset version",
    "changeset-publish": "pnpm build && changeset publish"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/sdk-trace-node": "2.8.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "22.13.9",
    "typescript": "5.8.2"
  },
  "pnpm": {
    "overrides": {
      "picomatch@2": "2.3.2",
      "read-yaml-file@1": "2.1.0"
    }
  },
  "author": "Inato",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
